{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.jobtracker.app",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/resources/",
  "url": "/index.html",
  "enableServer": true,
  "enableNativeAPI": true,
  "enableExtensions": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "debug.log",
    "filesystem.*",
    "storage.*",
    "extensions.*"
  ],
  "extensions": [
    {
      "id": "com.jobtracker.sqlite",
      "commandWindows": "\"${NL_PATH}/extensions/sqlite-ext/sqlite-ext.exe\" \"${NL_OSDATAPATH}/job-tracker/jobs.db\"",
      "commandLinux": "${NL_PATH}/extensions/sqlite-ext/sqlite-ext \"${NL_OSDATAPATH}/job-tracker/jobs.db\"",
      "commandDarwin": "${NL_PATH}/extensions/sqlite-ext/sqlite-ext \"${NL_OSDATAPATH}/job-tracker/jobs.db\""
    }
  ],
  "modes": {
    "window": {
      "title": "Job Tracker",
      "width": 1200,
      "height": 800,
      "minWidth": 900,
      "minHeight": 600,
      "center": true,
      "fullScreen": false,
      "alwaysOnTop": false,
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "Job Tracker",
    "resourcesPath": "/resources/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  }
}